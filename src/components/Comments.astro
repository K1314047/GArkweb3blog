---
import '../styles/twikoo.css';

const twikooEnv = 'https://mypinglun.vercel.app/api/twikoo';
const twikooAuthors = ['G.Ark', 'gark', 'Gark'];
---

<div id='twikoo'></div>

<script is:inline src='https://s4.zstatic.net/npm/twikoo@1.6.44/dist/twikoo.nocss.js'></script>

<script is:inline define:vars={{ twikooEnv, twikooAuthors }}>
	let twikooObserver;

	function markAuthorComments() {
		if (!Array.isArray(twikooAuthors) || twikooAuthors.length === 0) return;
		const comments = document.querySelectorAll('#twikoo .tk-comment');
		comments.forEach((comment) => {
			const nickEl = comment.querySelector('.tk-nick');
			if (!nickEl) return;
	
			const nick = nickEl.textContent?.trim();
			if (!nick) return;
	
			if (twikooAuthors.includes(nick)) {
				comment.classList.add('tk-comment-author');
	
				const nickParent = nickEl.closest('.tk-nick-link') || nickEl;
				if (nickParent && !nickParent.parentElement?.querySelector('.tk-author-badge')) {
					const badge = document.createElement('span');
					badge.className = 'tk-author-badge';
					badge.setAttribute('title', '博主');
					badge.innerHTML =
						'<svg width="15" height="15" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.882-1.687-.47-.445-1.053-.75-1.687-.882-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.969.855-1.24 1.44c-.608-.223-1.267-.272-1.902-.14-.635.13-1.22.436-1.69.882-.445.47-.749 1.055-.878 1.69-.13.635-.08 1.293.144 1.896-.587.274-1.087.705-1.443 1.245-.356.54-.555 1.17-.574 1.817.02.647.218 1.276.574 1.817.356.54.856.972 1.443 1.245-.224.604-.274 1.26-.144 1.896.13.636.433 1.221.878 1.69.47.447 1.055.752 1.69.883.635.13 1.294.083 1.902-.141.27.587.7 1.086 1.24 1.44.54.354 1.167.551 1.813.568.647-.016 1.276-.213 1.817-.567s.972-.854 1.245-1.44c.604.224 1.262.272 1.896.141.636-.13 1.22-.436 1.69-.883.445-.47.75-1.054.88-1.69.131-.635.084-1.292-.139-1.896.587-.273 1.084-.705 1.439-1.246.355-.54.551-1.17.569-1.816zM9.662 14.85l-3.429-3.428 1.293-1.302 2.072 2.072 4.4-4.794 1.347 1.246z" fill="currentColor"/></svg>';
					nickParent.after(badge);
				}
			}
		});
	}
	
	function observeTwikooChanges() {
		const twikooEl = document.getElementById('twikoo');
		if (!twikooEl) return;
	
		if (twikooObserver) {
			twikooObserver.disconnect();
		}
	
		twikooObserver = new MutationObserver(() => {
			markAuthorComments();
		});
	
		twikooObserver.observe(twikooEl, { childList: true, subtree: true });
		markAuthorComments();
	}
	
	function initTwikoo() {
		if (!twikooEnv) return;
		if (typeof twikoo === 'undefined') return;
	
		const twikooEl = document.getElementById('twikoo');
		if (!twikooEl) return;
	
		twikooEl.innerHTML = '';
	
		twikoo.init({
			envId: twikooEnv,
			el: '#twikoo',
			lang: 'zh-CN',
			path: location.pathname,
		});
	
		observeTwikooChanges();
	}
	
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initTwikoo);
	} else {
		initTwikoo();
	}
	
	document.addEventListener('astro:page-load', initTwikoo);
	
	document.addEventListener('astro:before-preparation', function () {
		const twikooEl = document.getElementById('twikoo');
		if (twikooEl) {
			twikooEl.innerHTML = '';
		}
	
		if (twikooObserver) {
			twikooObserver.disconnect();
			twikooObserver = undefined;
		}
	});
</script>
